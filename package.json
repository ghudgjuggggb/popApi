{
  "name": "popapi",
  "version": "1.0.0-beta",
  "description": "Fast and easy tool to batch upload files to GitHub. Works from Web UI, CLI, REST API, and programmatically",
  "main": "server.js",
  "bin": {
    "popapi": "./cli.js"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js --dev",
    "cli": "node cli.js",
    "test": "node cli.js help"
  },
  "keywords": [
    "github",
    "upload",
    "batch",
    "cli",
    "web",
    "files",
    "repository"
  ],
  "author": "popApi Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/popapi"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "dependencies": {
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "dotenv": "^16.0.3",
    "cors": "^2.8.5",
    "body-parser": "^1.20.2"
  },
  "devDependencies": {},
  "preferGlobal": true
}
